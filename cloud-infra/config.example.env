# ============================================================================
# MediaShield AI — Environment Variables
# ============================================================================
# Copy this file to `.env` and fill in your API keys and IDs.
#
# HOW TO GET KEYS:
#   Gemini API Key:       https://aistudio.google.com/apikey → Create API Key
#   GCP API Key:          https://console.cloud.google.com → APIs & Services → Credentials
#                         Enable: Cloud Vision API, Vertex AI API
#   Maps API Key:         Same GCP Console → Enable Maps JavaScript API
# ============================================================================

# ---------------------------------------------------------------------------
# Cloud project + infra
# ---------------------------------------------------------------------------
PROJECT_ID=your-gcp-project-id
PROJECT_NUMBER=your-gcp-project-number
REGION=us-central1
DATASET_ID=mediashield
BUCKET_NAME=gs://your-asset-bucket-name
LOG_ASSET_URL=https://REPLACE-WITH-LOG-ASSET-FUNCTION
LOG_VIOLATION_URL=https://REPLACE-WITH-LOG-VIOLATION-FUNCTION

# ---------------------------------------------------------------------------
# Frontend / AI engine (Vite reads VITE_*)
# ---------------------------------------------------------------------------
VITE_PROJECT_ID=your-gcp-project-id
VITE_DATASET_ID=mediashield
VITE_BUCKET_NAME=gs://your-asset-bucket-name
VITE_LOG_ASSET_URL=https://REPLACE-WITH-LOG-ASSET-FUNCTION
VITE_LOG_VIOLATION_URL=https://REPLACE-WITH-LOG-VIOLATION-FUNCTION

# Gemini 1.5/2.x — Used for asset analysis, threat classification, DMCA generation
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Platform — Used for Cloud Vision API and Vertex AI
VITE_GOOGLE_CLOUD_API_KEY=your_gcp_api_key_here

# Google Maps — Used for geo-visualization (Member 4)
VITE_MAPS_API_KEY=your_maps_api_key_here
